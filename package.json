{
  "name": "boku-no-jihanki",
  "private": true,
  "version": "0.1.0",
  "description": "夏休みの町を歩き回り、お金を集めてゲームを買いまくる探索RPG。",
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "tsc -b && vite build",
    "preview": "vite preview --host 0.0.0.0",
    "typecheck": "tsc -b --pretty false",
    "lint": "eslint . --max-warnings 0",
    "test": "node --test tests/*.test.mjs",
    "validate": "node scripts/validate-project.mjs",
    "validate:m15-assets": "python3 tools/art/validate_m15_assets.py",
    "check": "npm run validate && npm run validate:m15-assets && npm run lint && npm run typecheck && npm test && npm run build"
  },
  "engines": {
    "node": ">=22.14 <23"
  },
  "packageManager": "npm@10.9.2",
  "dependencies": {
    "phaser": "4.2.1",
    "react": "19.0.0",
    "react-dom": "19.0.0"
  },
  "devDependencies": {
    "@eslint/js": "9.22.0",
    "@types/node": "^22.13.10",
    "@types/react": "19.0.10",
    "@types/react-dom": "19.0.4",
    "@vitejs/plugin-react": "4.3.4",
    "eslint": "9.22.0",
    "eslint-plugin-react-hooks": "5.2.0",
    "eslint-plugin-react-refresh": "0.4.19",
    "globals": "16.0.0",
    "typescript": "5.7.2",
    "typescript-eslint": "8.26.1",
    "vite": "6.3.1"
  }
}
